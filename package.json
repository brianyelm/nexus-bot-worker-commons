    "./handlers/handleChatMessage": "./src/handlers/handleChatMessage.js",
    "./handlers/handleCommandList": "./src/handlers/handleCommandList.js",
    "./lib/anthropic": "./src/lib/anthropic.js",
    "./lib/callbackSign": "./src/lib/callbackSign.js",
    "./lib/commandParser": "./src/lib/commandParser.js",
    "./lib/history": "./src/lib/history.js",
    "./lib/memory": "./src/lib/memory.js",
    "./lib/nexus": "./src/lib/nexus.js",
    "./lib/hitl": "./src/lib/hitl.js",
    "./lib/triggers": "./src/lib/triggers.js",
    "./lib/attachments": "./src/lib/attachments.js",
    "./lib/memoryService": "./src/lib/memoryService.js"
  },
  "files": [
    "src/",
    "migrations/",
    "SPEC.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/"
  },
  "engines": {
    "node": ">=20"
  }
}
